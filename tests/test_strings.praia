use "testing"

testing.test("concatenation and length", lam{ in
    testing.assertEqual("hello" + " " + "world", "hello world", nil)
    testing.assertEqual(len("praia"), 5, nil)
    testing.assertEqual(len(""), 0, nil)
})

testing.test("interpolation", lam{ in
    let name = "Ada"
    let age = 36
    testing.assertEqual("%{name} is %{age}", "Ada is 36", nil)
    testing.assertEqual("%{1 + 1}", "2", nil)
})

testing.test("case conversion", lam{ in
    testing.assertEqual("Hello".upper(), "HELLO", nil)
    testing.assertEqual("HELLO".lower(), "hello", nil)
    testing.assertEqual("hello world".title(), "Hello World", nil)
    testing.assertEqual("hello".capitalize(), "Hello", nil)
})

testing.test("strip and split", lam{ in
    testing.assertEqual("  hi  ".strip(), "hi", nil)
    let parts = "a,b,c".split(",")
    testing.assertEqual(len(parts), 3, nil)
    testing.assertEqual(parts[0], "a", nil)
    testing.assertEqual(parts[2], "c", nil)
})

testing.test("replace and contains", lam{ in
    testing.assertEqual("hello world".replace("world", "praia"), "hello praia", nil)
    testing.assert("foobar".contains("oob"), nil)
    testing.assert(!"foobar".contains("xyz"), nil)
})

testing.test("startsWith / endsWith", lam{ in
    testing.assert("foobar".startsWith("foo"), nil)
    testing.assert(!"foobar".startsWith("bar"), nil)
    testing.assert("foobar".endsWith("bar"), nil)
    testing.assert(!"foobar".endsWith("foo"), nil)
})

testing.test("indexing", lam{ in
    testing.assertEqual("hello"[0], "h", nil)
    testing.assertEqual("hello"[4], "o", nil)
    testing.assertEqual("hello"[-1], "o", nil)
})

testing.test("regex", lam{ in
    testing.assert("abc123".test("[0-9]+"), nil)
    let m = "year 2026".match("[0-9]+")
    testing.assertEqual(m.match, "2026", nil)
})

testing.test("string multiplication", lam{ in
    testing.assertEqual("ab" * 3, "ababab", nil)
    testing.assertEqual(3 * "ha", "hahaha", nil)
    testing.assertEqual("x" * 0, "", nil)
    testing.assertEqual("hi" * 1, "hi", nil)
})

testing.done()
