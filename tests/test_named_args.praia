use "testing"

testing.test("basic named args", lam{ in
    func f(a, b, c) { return [a, b, c] }
    testing.assertEqual(f(a: 1, b: 2, c: 3), [1, 2, 3], nil)
})

testing.test("mixed positional and named", lam{ in
    func f(a, b, c) { return [a, b, c] }
    testing.assertEqual(f(1, c: 3, b: 2), [1, 2, 3], nil)
})

testing.test("named args with defaults", lam{ in
    func f(a, b = 10, c = 20) { return [a, b, c] }
    testing.assertEqual(f(1), [1, 10, 20], nil)
    testing.assertEqual(f(1, c: 30), [1, 10, 30], nil)
    testing.assertEqual(f(a: 1, c: 30), [1, 10, 30], nil)
})

testing.test("all positional still works", lam{ in
    func f(a, b, c) { return a + b + c }
    testing.assertEqual(f(1, 2, 3), 6, nil)
})

testing.test("class constructor with named args", lam{ in
    class Point {
        func init(x, y) { this.x = x; this.y = y }
    }
    let p = Point(y: 20, x: 10)
    testing.assertEqual(p.x, 10, nil)
    testing.assertEqual(p.y, 20, nil)
})

testing.test("lambda with named args", lam{ in
    let add = lam{ a, b = 0 in a + b }
    testing.assertEqual(add(b: 10, a: 5), 15, nil)
})

testing.test("unknown name throws", lam{ in
    func f(a) { return a }
    testing.assertThrows(lam{ in f(x: 1) }, nil)
})

testing.test("native function rejects named args", lam{ in
    testing.assertThrows(lam{ in len(x: [1]) }, nil)
})

testing.test("named args through async", lam{ in
    func f(a, b, c) { return [a, b, c] }
    let fut = async f(b: 2, a: 1, c: 3)
    testing.assertEqual(await fut, [1, 2, 3], nil)
})

testing.test("named args through pipe", lam{ in
    func f(a, b, c) { return [a, b, c] }
    let r = 10 |> f(c: 30, b: 20)
    testing.assertEqual(r, [10, 20, 30], nil)
})

testing.test("named args through pipe with defaults", lam{ in
    func f(a, b = 5, c = 9) { return [a, b, c] }
    let r = 1 |> f(c: 3)
    testing.assertEqual(r, [1, 5, 3], nil)
})

testing.done()
