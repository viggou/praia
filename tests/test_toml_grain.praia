use "testing"
use "toml"

testing.test("parse simple", lam{ in
    let data = toml.parse("name = \"Ada\"\nage = 36")
    testing.assertEqual(data.name, "Ada", nil)
    testing.assertEqual(data.age, 36, nil)
})

testing.test("parse booleans", lam{ in
    let data = toml.parse("a = true\nb = false")
    testing.assertEqual(data.a, true, nil)
    testing.assertEqual(data.b, false, nil)
})

testing.test("parse tables", lam{ in
    let data = toml.parse("[server]\nhost = \"localhost\"\nport = 8080")
    testing.assertEqual(data.server.host, "localhost", nil)
    testing.assertEqual(data.server.port, 8080, nil)
})

testing.test("parse arrays", lam{ in
    let data = toml.parse("nums = [1, 2, 3]")
    testing.assertEqual(data.nums, [1, 2, 3], nil)
})

testing.test("stringify", lam{ in
    let result = toml.stringify({name: "Ada", age: 36})
    testing.assert(result.contains("name = \"Ada\""), nil)
    testing.assert(result.contains("age = 36"), nil)
})

testing.done()
