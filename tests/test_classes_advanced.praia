use "testing"

testing.test("class with init and methods", lam{ in
    class Point {
        init(x, y) {
            this.x = x
            this.y = y
        }
        magnitude() {
            return math.sqrt(this.x * this.x + this.y * this.y)
        }
        format() {
            return "(%{this.x}, %{this.y})"
        }
    }
    let p = Point(3, 4)
    testing.assertEqual(p.x, 3, nil)
    testing.assertEqual(p.magnitude(), 5, nil)
    testing.assertEqual(p.format(), "(3, 4)", nil)
})

testing.test("multi-level inheritance with super", lam{ in
    class A {
        greet() { return "A" }
    }
    class B extends A {
        greet() { return "B+" + super.greet() }
    }
    class C extends B {
        greet() { return "C+" + super.greet() }
    }
    testing.assertEqual(A().greet(), "A", nil)
    testing.assertEqual(B().greet(), "B+A", nil)
    testing.assertEqual(C().greet(), "C+B+A", nil)
})

testing.test("inherited method with super does not recurse", lam{ in
    class Base {
        m() { return "base" }
    }
    class Mid extends Base {
        m() { return "mid+" + super.m() }
    }
    class Leaf extends Mid {}
    // Leaf inherits Mid.m(), which calls super.m() -> Base.m()
    testing.assertEqual(Leaf().m(), "mid+base", nil)
})

testing.test("inherited init", lam{ in
    class Animal {
        init(name) { this.name = name }
        speak() { return this.name }
    }
    class Dog extends Animal {}
    let d = Dog("Rex")
    testing.assertEqual(d.name, "Rex", nil)
    testing.assertEqual(d.speak(), "Rex", nil)
})

testing.test("method default params", lam{ in
    class Calc {
        add(a, b = 10) { return a + b }
    }
    let c = Calc()
    testing.assertEqual(c.add(5), 15, nil)
    testing.assertEqual(c.add(5, 3), 8, nil)
})

testing.test("str() calls toString()", lam{ in
    class Person {
        init(name) { this.name = name }
        toString() { return this.name }
    }
    let p = Person("Ada")
    testing.assertEqual(str(p), "Ada", nil)
})

testing.done()
