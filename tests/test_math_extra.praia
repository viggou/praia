use "testing"

testing.test("math.idiv positive", lam{ in
    testing.assertEqual(math.idiv(7, 2), 3, nil)
    testing.assertEqual(math.idiv(10, 3), 3, nil)
    testing.assertEqual(math.idiv(9, 3), 3, nil)
    testing.assertEqual(math.idiv(1, 1), 1, nil)
})

testing.test("math.idiv negative", lam{ in
    testing.assertEqual(math.idiv(-7, 2), -3, nil)
    testing.assertEqual(math.idiv(7, -2), -3, nil)
    testing.assertEqual(math.idiv(-7, -2), 3, nil)
})

testing.test("math.idiv by zero throws", lam{ in
    testing.assertThrows(lam{ in math.idiv(1, 0) }, nil)
})

testing.test("math.trunc positive", lam{ in
    testing.assertEqual(math.trunc(3.7), 3, nil)
    testing.assertEqual(math.trunc(3.0), 3, nil)
    testing.assertEqual(math.trunc(0.9), 0, nil)
})

testing.test("math.trunc negative", lam{ in
    testing.assertEqual(math.trunc(-3.7), -3, nil)
    testing.assertEqual(math.trunc(-0.1), 0, nil)
})

testing.test("math.trunc on integer", lam{ in
    testing.assertEqual(math.trunc(42), 42, nil)
})

testing.done()
