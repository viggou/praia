let PI = 3.14159265358979
let E = 2.71828182845905

func square(x) { return x * x }
func cube(x) { return x * x * x }
func abs(x) { if (x < 0) { return -x } return x }
func max(a, b) { if (a > b) { return a } return b }
func min(a, b) { if (a < b) { return a } return b }
func clamp(x, lo, hi) { return max(lo, min(x, hi)) }

export { PI, E, square, cube, abs, max, min, clamp }
